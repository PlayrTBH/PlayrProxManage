# Proxmox Manager — environment configuration
# Installed to /etc/proxmox-manager/proxmox-manager.env
# This file contains secrets: keep it root-readable only (chmod 600).

# --- web service ---
# Bind localhost; nginx terminates TLS and proxies to this. Only change
# BIND_HOST to 0.0.0.0 if you are NOT using the bundled reverse proxy.
BIND_HOST=127.0.0.1
BIND_PORT=8800

# --- storage ---
DB_PATH=/var/lib/proxmox-manager/app.db

# --- clusters ---
# Cluster connection details live in this separate JSON file.
CLUSTERS_FILE=/etc/proxmox-manager/clusters.json

# --- poller ---
POLL_INTERVAL=30
HISTORY_RETENTION_DAYS=30

# --- sessions / auth ---
# Generated by the installer. Rotating this invalidates all sessions.
SESSION_SECRET=__REPLACE_ME__

# Set to false ONLY if serving plain HTTP (not recommended).
COOKIE_SECURE=true

# Bootstrap admin — created on first run only, when the DB has no users.
BOOTSTRAP_ADMIN_USER=admin
# Generate with:  python3 -m app.hashpw
BOOTSTRAP_ADMIN_PASSWORD_HASH=__REPLACE_ME__

# Login brute-force protection.
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300

# --- invites ---
# Externally reachable base URL of this app (behind your VPN/Tunnel).
# Used to build invite links in emails. No trailing slash.
PUBLIC_BASE_URL=https://pmx.example.com
# How many days an invite link stays valid.
INVITE_EXPIRY_DAYS=7

# --- SMTP (for sending invite emails) ---
# If SMTP_HOST and SMTP_FROM are left blank, invites still work: the admin
# UI shows the invite link to copy and send manually.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Proxmox Manager <noreply@example.com>
# Use one of these, not both:
#   STARTTLS on a plain connection (port 587) — the common case:
SMTP_STARTTLS=true
#   Implicit TLS (port 465) — set true and STARTTLS false instead:
SMTP_USE_SSL=false

